<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AndyTV.Maui.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AndyTV.Data.Models;assembly=AndyTV.Data"
    xmlns:vm="clr-namespace:AndyTV.Maui.ViewModels"
    xmlns:sfListView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    Title="Settings"
    x:DataType="vm:SettingsViewModel">

    <ScrollView>
    <Grid
        Padding="16"
        RowDefinitions="Auto,Auto,Auto,Auto"
        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

        <!--  Add Playlist Form  -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Add Playlist"
                Margin="0,4,0,4" />

            <Border
                StrokeShape="RoundRectangle 8"
                Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceRaisedLight}, Dark={StaticResource SurfaceRaisedDark}}"
                Padding="10,0">
                <Entry
                    Placeholder="Playlist Name"
                    Text="{Binding PlaylistName}"
                    BackgroundColor="Transparent"
                    FontSize="15" />
            </Border>

            <Border
                StrokeShape="RoundRectangle 8"
                Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceRaisedLight}, Dark={StaticResource SurfaceRaisedDark}}"
                Padding="10,0">
                <Entry
                    Placeholder="https://example.com/playlist.m3u or C:\Playlists\tv.m3u"
                    Text="{Binding PlaylistUrl}"
                    BackgroundColor="Transparent"
                    FontSize="15" />
            </Border>

            <Button
                Command="{Binding AddCommand}"
                Text="Add Playlist"
                Margin="0,4,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <BoxView
                Margin="0,14"
                HeightRequest="1"
                Color="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="My Playlists"
                Margin="0,0,0,4" />
        </VerticalStackLayout>

        <!--  Playlist List (drag to reorder)  -->
        <sfListView:SfListView
            x:Name="playlistListView"
            Grid.Row="1"
            Margin="0,8,0,0"
            ItemsSource="{Binding Playlists}"
            ItemSize="62"
            DragStartMode="OnDragIndicator"
            SelectionMode="None">
            <sfListView:SfListView.ItemTemplate>
                <DataTemplate x:DataType="models:Playlist">
                    <Border
                        Margin="0,4"
                        Padding="12,10"
                        StrokeShape="RoundRectangle 8"
                        Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceRaisedLight}, Dark={StaticResource SurfaceRaisedDark}}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <sfListView:DragIndicatorView
                                Grid.Column="0"
                                ListView="{x:Reference playlistListView}"
                                VerticalOptions="Center"
                                Margin="0,0,12,0">
                                <Label
                                    FontFamily="FontAwesomeSolid"
                                    Text="&#xf58e;"
                                    FontSize="18"
                                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    VerticalOptions="Center" />
                            </sfListView:DragIndicatorView>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    LineBreakMode="TailTruncation"
                                    Text="{Binding Name}" />
                                <Label
                                    FontSize="12"
                                    LineBreakMode="TailTruncation"
                                    Text="{Binding Url}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                            </VerticalStackLayout>
                            <ImageButton
                                Grid.Column="2"
                                BackgroundColor="Transparent"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                                CommandParameter="{Binding .}"
                                HeightRequest="36"
                                WidthRequest="36">
                                <ImageButton.Source>
                                    <FontImageSource
                                        FontFamily="FontAwesomeSolid"
                                        Glyph="&#xf1f8;"
                                        Size="16"
                                        Color="{StaticResource Danger}" />
                                </ImageButton.Source>
                            </ImageButton>
                        </Grid>
                    </Border>
                </DataTemplate>
            </sfListView:SfListView.ItemTemplate>
        </sfListView:SfListView>

        <!--  Local Streaming Config  -->
        <VerticalStackLayout Grid.Row="2" Spacing="12" Margin="0,14,0,0">
            <BoxView
                HeightRequest="1"
                Color="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Local Streaming"
                Margin="0,4,0,4" />

            <Border
                StrokeShape="RoundRectangle 8"
                Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceRaisedLight}, Dark={StaticResource SurfaceRaisedDark}}"
                Padding="10,0">
                <Entry
                    Placeholder="http://192.168.1.100:8080"
                    Text="{Binding LocalServerUrl}"
                    BackgroundColor="Transparent"
                    FontSize="15"
                    Keyboard="Url" />
            </Border>

            <Border
                StrokeShape="RoundRectangle 8"
                Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceRaisedLight}, Dark={StaticResource SurfaceRaisedDark}}"
                Padding="10,4">
                <Picker
                    Title="Quality"
                    ItemsSource="{x:Static vm:SettingsViewModel.QualityOptions}"
                    SelectedItem="{Binding SelectedQuality}" />
            </Border>
        </VerticalStackLayout>

        <Label
            Grid.Row="3"
            HorizontalOptions="Center"
            Margin="0,10,0,0"
            Text="{x:Static vm:SettingsViewModel.AppVersion}"
            TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
            FontSize="12" />
    </Grid>
    </ScrollView>
</ContentPage>
