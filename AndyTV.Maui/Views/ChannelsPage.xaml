<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AndyTV.Maui.Views.ChannelsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AndyTV.Data.Models;assembly=AndyTV.Data"
    xmlns:vm="clr-namespace:AndyTV.Maui.ViewModels"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:sfListView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:sfDataSource="clr-namespace:Syncfusion.Maui.DataSource;assembly=Syncfusion.Maui.DataSource"
    Title="Channels"
    x:DataType="vm:ChannelsViewModel">

    <ContentPage.Resources>
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="IsStringNotNullOrEmptyConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Search Bar -->
        <Border
            Grid.Row="0"
            Margin="12,12,12,6"
            Padding="4"
            StrokeShape="RoundRectangle 12"
            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
            BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#2A2A2A}">
            <Grid ColumnDefinitions="Auto,*">
                <Label
                    Grid.Column="0"
                    FontFamily="FontAwesomeSolid"
                    Text="&#xf002;"
                    FontSize="16"
                    TextColor="{StaticResource Gray400}"
                    VerticalOptions="Center"
                    Margin="12,0,8,0" />
                <Entry
                    Grid.Column="1"
                    Placeholder="Search channels (min 2 chars)..."
                    Text="{Binding SearchText}"
                    BackgroundColor="Transparent"
                    FontSize="15" />
            </Grid>
        </Border>

        <!-- Syncfusion ListView with collapsible groups -->
        <sfListView:SfListView
            Grid.Row="1"
            ItemsSource="{Binding Channels}"
            ItemSize="64"
            GroupHeaderSize="48"
            AllowGroupExpandCollapse="True"
            SelectionMode="None">

            <sfListView:SfListView.DataSource>
                <sfDataSource:DataSource>
                    <sfDataSource:DataSource.GroupDescriptors>
                        <sfDataSource:GroupDescriptor PropertyName="Category" />
                    </sfDataSource:DataSource.GroupDescriptors>
                </sfDataSource:DataSource>
            </sfListView:SfListView.DataSource>

            <sfListView:SfListView.GroupHeaderTemplate>
                <DataTemplate x:DataType="x:Object">
                    <Grid
                        Padding="16,8"
                        BackgroundColor="{AppThemeBinding Light=#EDE7F6, Dark=#1E1E2E}"
                        ColumnDefinitions="Auto,*,Auto">
                        <Label
                            Grid.Column="0"
                            FontFamily="FontAwesomeSolid"
                            Text="&#xf105;"
                            FontSize="14"
                            TextColor="{StaticResource Primary}"
                            VerticalOptions="Center"
                            Margin="0,0,10,0" />
                        <Label
                            Grid.Column="1"
                            FontAttributes="Bold"
                            FontSize="16"
                            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            VerticalOptions="Center"
                            Text="{Binding Key}" />
                        <Label
                            Grid.Column="2"
                            FontSize="12"
                            TextColor="{StaticResource Gray400}"
                            VerticalOptions="Center"
                            Margin="0,0,12,0"
                            Text="{Binding Count, StringFormat='{0} channels'}" />
                    </Grid>
                </DataTemplate>
            </sfListView:SfListView.GroupHeaderTemplate>

            <sfListView:SfListView.ItemTemplate>
                <DataTemplate x:DataType="models:Channel">
                    <Grid Padding="16,8" ColumnDefinitions="Auto,*,Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectChannelCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <Border
                            Grid.Column="0"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                            HeightRequest="44"
                            WidthRequest="44"
                            Margin="0,0,12,0"
                            IsVisible="{Binding LogoUrl, Converter={StaticResource IsStringNotNullOrEmptyConverter}}">
                            <Image
                                Aspect="AspectFit"
                                HeightRequest="36"
                                WidthRequest="36"
                                Source="{Binding LogoUrl}" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label FontSize="15" FontAttributes="Bold" Text="{Binding Name}" />
                            <Label
                                FontSize="12"
                                Text="{Binding Category}"
                                TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>

                        <ImageButton
                            Grid.Column="2"
                            BackgroundColor="Transparent"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleFavoriteCommand}"
                            CommandParameter="{Binding .}"
                            HeightRequest="40"
                            WidthRequest="40">
                            <ImageButton.Source>
                                <FontImageSource
                                    FontFamily="FontAwesomeRegular"
                                    Glyph="&#xf005;"
                                    Size="22"
                                    Color="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray500}}" />
                            </ImageButton.Source>
                        </ImageButton>
                    </Grid>
                </DataTemplate>
            </sfListView:SfListView.ItemTemplate>
        </sfListView:SfListView>
    </Grid>
</ContentPage>