<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AndyTV.Maui.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AndyTV.Data.Models;assembly=AndyTV.Data"
    xmlns:vm="clr-namespace:AndyTV.Maui.ViewModels"
    Title="Favorites"
    x:DataType="vm:FavoritesViewModel">

    <RefreshView
        Command="{Binding LoadFavoritesCommand}"
        IsRefreshing="{Binding IsRefreshing}"
        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
        <CollectionView
            ItemsSource="{Binding Favorites}"
            SelectionMode="None"
            Margin="8,8,8,10">
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="8"
                    Padding="40">
                    <Label
                        FontFamily="FontAwesomeLight"
                        Text="&#xf005;"
                        FontSize="42"
                        HorizontalOptions="Center"
                        TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray500}}" />
                    <Label
                        Text="No favorites yet"
                        FontSize="16"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                    <Label
                        Text="Star channels from the Channels tab to add them here."
                        FontSize="14"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Channel">
                    <Border
                        Margin="0,4"
                        Padding="12,10"
                        StrokeShape="RoundRectangle 8"
                        Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceRaisedLight}, Dark={StaticResource SurfaceRaisedDark}}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectChannelCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <Label
                                Grid.Column="0"
                                FontFamily="FontAwesomeSolid"
                                Text="&#xf005;"
                                FontSize="16"
                                TextColor="{StaticResource Favorite}"
                                VerticalOptions="Center"
                                Margin="0,0,12,0" />

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    LineBreakMode="TailTruncation"
                                    Text="{Binding DisplayName}" />
                                <Label
                                    FontSize="12"
                                    Text="{Binding Category}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                            </VerticalStackLayout>

                            <ImageButton
                                Grid.Column="2"
                                BackgroundColor="Transparent"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFavoriteCommand}"
                                CommandParameter="{Binding .}"
                                HeightRequest="36"
                                WidthRequest="36">
                                <ImageButton.Source>
                                <FontImageSource
                                    FontFamily="FontAwesomeSolid"
                                    Glyph="&#xf00d;"
                                    Size="16"
                                    Color="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                            </ImageButton.Source>
                        </ImageButton>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>
