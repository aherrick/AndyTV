<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AndyTV.Maui.MainPage">

    <VerticalStackLayout Padding="20" Spacing="12" VerticalOptions="Center">
        <Entry
            x:Name="HlsUrlEntry"
            Placeholder="Enter .m3u8 URL" />

        <Button
            Text="Play HLS"
            Clicked="OnPlayClicked" />
    </VerticalStackLayout>
</ContentPage>
