<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AndyTV.Maui.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="Black">

    <VerticalStackLayout
        Padding="20"
        Spacing="12"
        VerticalOptions="Center">
        <Entry
            x:Name="HlsUrlEntry"
            Placeholder="Enter .m3u8 URL"
            PlaceholderColor="Gray"
            Text="https://gohyperspeed.com/2021194346/CVAmoUn2bF/200163534"
            TextColor="White" />

        <Button Clicked="OnPlayClicked" Text="Play HLS" />
    </VerticalStackLayout>
</ContentPage>